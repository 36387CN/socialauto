<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - 社媒自动化助手</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-layout">
        <nav class="sidebar">
            <div class="sidebar-header">
                <h2>社媒自动化助手</h2>
            </div>
            <ul class="nav-list">
                <li><a href="/dashboard" class="nav-item active">&#9632; 控制台</a></li>
                <li><a href="/dashboard/posts" class="nav-item">&#9998; 内容管理</a></li>
                <li><a href="/dashboard/analytics" class="nav-item">&#128200; 数据分析</a></li>
                <li><a href="/dashboard/referral" class="nav-item">&#127881; 推荐好友</a></li>
                <li><a href="/dashboard/settings" class="nav-item">&#9881; 设置</a></li>
            </ul>
            <div class="sidebar-footer">
                <span><%= user.name || user.email %></span>
                <a href="/auth/logout" class="btn-small">退出</a>
            </div>
        </nav>
        <main class="main-content">
            <h1>控制台</h1>

            <div class="free-banner" style="background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border-radius:10px;padding:15px 20px;margin-bottom:25px;display:flex;justify-content:space-between;align-items:center;">
                <span>&#128161; 免费试用剩余 <strong><%= freeDays %></strong> 天</span>
                <a href="/dashboard/referral" style="color:#fff;text-decoration:underline;">推荐好友延长试用 &rarr;</a>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-value"><%= totalPosts %></div>
                    <div class="stat-label">总内容数</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= totalImpressions %></div>
                    <div class="stat-label">总曝光</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= totalClicks %></div>
                    <div class="stat-label">总点击</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= referrals %></div>
                    <div class="stat-label">推荐成功</div>
                </div>
            </div>

            <section class="section">
                <div class="section-header">
                    <h2>最近内容</h2>
                    <a href="/dashboard/posts/new" class="btn-primary btn-small">+ 新建</a>
                </div>
                <table class="table">
                    <thead>
                        <tr>
                            <th>内容</th>
                            <th>平台</th>
                            <th>状态</th>
                            <th>排期</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (posts.length === 0) { %>
                            <tr><td colspan="4" class="empty">暂无内容，<a href="/dashboard/posts/new">新建第一条内容</a></td></tr>
                        <% } %>
                        <% posts.forEach(function(p) { %>
                            <tr>
                                <td class="truncate"><%= p.content.substring(0, 40) %></td>
                                <td><%= p.platform %></td>
                                <td><span class="badge badge-<%= p.status %>"><%= p.status === "scheduled" ? "已排期" : p.status === "draft" ? "草稿" : p.status %></span></td>
                                <td><%= p.scheduled_at ? new Date(p.scheduled_at).toLocaleString("zh-CN") : "-" %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </section>
        </main>
    </div>
</body>
</html>
