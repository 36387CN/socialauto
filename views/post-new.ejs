<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - 社媒自动化助手</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="app-layout">
        <nav class="sidebar">
            <div class="sidebar-header">
                <h2>社媒自动化助手</h2>
            </div>
            <ul class="nav-list">
                <li><a href="/dashboard" class="nav-item">控制台</a></li>
                <li><a href="/dashboard/posts" class="nav-item active">内容管理</a></li>
                <li><a href="/dashboard/analytics" class="nav-item">数据分析</a></li>
                <li><a href="/dashboard/settings" class="nav-item">设置</a></li>
            </ul>
            <div class="sidebar-footer">
                <span><%= user.name || user.email %></span>
                <a href="/auth/logout" class="btn-small">退出</a>
            </div>
        </nav>
        <main class="main-content">
            <div class="section-header">
                <h1>新建内容</h1>
                <a href="/dashboard/posts" class="btn-secondary">&larr; 返回</a>
            </div>

            <form method="POST" action="/dashboard/posts" class="post-form">
                <div class="form-group">
                    <label>内容 *</label>
                    <textarea name="content" rows="5" placeholder="输入您要发布的内容..." required></textarea>
                </div>
                <div class="form-group">
                    <label>平台 *</label>
                    <select name="platform" required>
                        <option value="">选择平台</option>
                        <option value="微信朋友圈">微信朋友圈</option>
                        <option value="微博">微博</option>
                        <option value="抖音">抖音</option>
                        <option value="小红书">小红书</option>
                        <option value="公众号">公众号</option>
                        <option value="多平台">多平台</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>排期时间（可选）</label>
                    <input type="datetime-local" name="scheduled_at">
                    <small>留空则保存为草稿</small>
                </div>
                <button type="submit" class="btn-primary">创建</button>
            </form>
        </main>
    </div>
</body>
</html>
