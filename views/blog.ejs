<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - 社媒自动化助手</title>
    <link rel="stylesheet" href="/css/style.css">
    <meta name="description" content="小企业社媒运营技巧、朋友圈营销教程、抖音运营入门 - 免费学习">
</head>
<body>
    <div class="blog-layout">
        <nav class="blog-nav">
            <div class="container" style="display:flex;justify-content:space-between;align-items:center;padding:15px 0;">
                <a href="/" style="font-weight:bold;color:#4a90e2;text-decoration:none;font-size:1.1rem;">&#128240; 社媒自动化助手 - 博客</a>
                <div>
                    <a href="/auth/login" style="margin-right:15px;color:#666;text-decoration:none;">登录</a>
                    <a href="/auth/register" class="btn-primary btn-small">免费试用</a>
                </div>
            </div>
        </nav>
        <div class="container" style="padding:30px 0;">
            <h1 style="margin-bottom:8px;">社媒运营博客</h1>
            <p style="color:#888;margin-bottom:30px;">小企业社媒运营技巧、案例、工具推荐</p>
            <div class="blog-grid">
                <% if (posts.length === 0) { %>
                    <p>暂无文章</p>
                <% } %>
                <% posts.forEach(function(p) { %>
                    <a href="/blog/<%= p.slug %>" style="text-decoration:none;color:inherit;">
                        <div class="blog-card" style="background:#fff;border-radius:10px;padding:25px;margin-bottom:20px;box-shadow:0 2px 8px rgba(0,0,0,0.06);transition:transform 0.2s;">
                            <h3 style="color:#333;margin-bottom:8px;"><%= p.title %></h3>
                            <p style="color:#888;font-size:0.9rem;margin-bottom:10px;"><%= p.summary %></p>
                            <div style="display:flex;justify-content:space-between;font-size:0.8rem;color:#aaa;">
                                <span><%= p.tags %></span>
                                <span><%= new Date(p.created_at).toLocaleDateString("zh-CN") %> &middot; <%= p.views %> 次阅读</span>
                            </div>
                        </div>
                    </a>
                <% }) %>
            </div>
        </div>
        <footer style="text-align:center;padding:20px;color:#888;font-size:0.85rem;">
            &copy; 2026 社媒自动化助手 &middot; <a href="/" style="color:#4a90e2;">首页</a> &middot; <a href="/templates/list" style="color:#4a90e2;">免费模板</a>
        </footer>
    </div>
</body>
</html>
